{
  "name": "@vben/styles",
  "version": "5.6.6",
  "homepage": "https://github.com/vbenjs/vue-vben-admin",
  "bugs": "https://github.com/vbenjs/vue-vben-admin/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbenjs/vue-vben-admin.git",
    "directory": "packages/styles"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.mjs",
      "development": "./src/index.ts"
    },
    "./antd": {
      "default": "./dist/antd/index.css",
      "development": "./src/antd/index.css"
    },
    "./antdv-next": {
      "default": "./dist/antdv-next/index.css",
      "development": "./src/antdv-next/index.css"
    },
    "./ele": {
      "default": "./dist/ele/index.css",
      "development": "./src/ele/index.css"
    },
    "./naive": {
      "default": "./dist/naive/index.css",
      "development": "./src/naive/index.css"
    },
    "./global": {
      "default": "./dist/global/index.scss",
      "development": "./src/global/index.scss"
    }
  },
  "dependencies": {
    "@vben-core/design": "workspace:*"
  },
  "scripts": {
    "build": "pnpm unbuild && node scripts/copy-assets.mjs",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "./antd": {
        "default": "./dist/antd/index.css"
      },
      "./antdv-next": {
        "default": "./dist/antdv-next/index.css"
      },
      "./ele": {
        "default": "./dist/ele/index.css"
      },
      "./naive": {
        "default": "./dist/naive/index.css"
      },
      "./global": {
        "default": "./dist/global/index.scss"
      }
    }
  }
}
