{
  "name": "@vben/plugins",
  "version": "5.6.6",
  "homepage": "https://github.com/vbenjs/vue-vben-admin",
  "bugs": "https://github.com/vbenjs/vue-vben-admin/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbenjs/vue-vben-admin.git",
    "directory": "packages/effects/plugins"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./echarts": {
      "types": "./src/echarts/index.ts",
      "default": "./dist/echarts/index.mjs",
      "development": "./src/echarts/index.ts"
    },
    "./vxe-table": {
      "types": "./src/vxe-table/index.ts",
      "default": "./dist/vxe-table/index.mjs",
      "development": "./src/vxe-table/index.ts"
    },
    "./motion": {
      "types": "./src/motion/index.ts",
      "default": "./dist/motion/index.mjs",
      "development": "./src/motion/index.ts"
    }
  },
  "dependencies": {
    "@vben-core/form-ui": "workspace:*",
    "@vben-core/shadcn-ui": "workspace:*",
    "@vben-core/shared": "workspace:*",
    "@vben/hooks": "workspace:*",
    "@vben/icons": "workspace:*",
    "@vben/locales": "workspace:*",
    "@vben/preferences": "workspace:*",
    "@vben/types": "workspace:*",
    "@vben/utils": "workspace:*",
    "@vueuse/core": "catalog:",
    "@vueuse/motion": "catalog:",
    "echarts": "catalog:",
    "vue": "catalog:",
    "vxe-pc-ui": "catalog:",
    "vxe-table": "catalog:"
  },
  "scripts": {
    "build": "pnpm unbuild && node scripts/copy-assets.mjs && vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly --noEmit false --outDir dist",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "exports": {
      "./echarts": {
        "types": "./dist/echarts/index.d.ts",
        "default": "./dist/echarts/index.mjs"
      },
      "./vxe-table": {
        "types": "./dist/vxe-table/index.d.ts",
        "default": "./dist/vxe-table/index.mjs"
      },
      "./motion": {
        "types": "./dist/motion/index.d.ts",
        "default": "./dist/motion/index.mjs"
      }
    }
  }
}
